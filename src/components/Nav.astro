---
import ExternalLink from "./ExternalLink.astro";

const aboutLinks = [
  { label: "Mission Statement", href: "/about/mission-statement" },
  { label: "Leadership", href: "/about/leadership" },
  { label: "About Us", href: "/about" }
];

const getInvolvedLinks = [
  { label: "Upcoming at NCI", href: "/upcoming-at-nci" },
  { label: "Resources", href: "/resources" }
];
---

<header class="site-nav">
  <div class="container site-nav__inner">
    <a href="/" class="site-nav__brand" aria-label="Nature Coast Indivisible home">
      <img src="/images/NCI-logo.svg" alt="Nature Coast Indivisible" />
    </a>

    <button
      type="button"
      class="site-nav__mobile-toggle"
      data-mobile-menu-toggle
      aria-expanded="false"
      aria-controls="mobile-nav-panel"
      aria-label="Open navigation menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav aria-label="Main navigation" class="site-nav__links">
      <ul>
        <li><a href="/">Home</a></li>
        <li>
          <button class="site-nav__toggle" type="button" data-menu-toggle="about" aria-expanded="false">
            About
          </button>
        </li>
        <li>
          <button
            class="site-nav__toggle"
            type="button"
            data-menu-toggle="get-involved"
            aria-expanded="false"
          >
            Get Involved
          </button>
        </li>
        <li><a href="/on-the-ground">On The Ground</a></li>
      </ul>
    </nav>

    <div class="site-nav__actions">
      <a href="/donate" class="button button--yellow">Donate</a>
      <ExternalLink
        href="https://www.facebook.com"
        class="facebook-link"
        aria-label="Visit Nature Coast Indivisible on Facebook"
      >
        <img src="/images/facebook.svg" alt="" aria-hidden="true" />
      </ExternalLink>
    </div>
  </div>

  <div class="site-nav__submenu-bar" data-menu-panel="about" hidden>
    <div class="container">
      <ul class="site-nav__submenu-list">
        {aboutLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
      </ul>
    </div>
  </div>

  <div class="site-nav__submenu-bar" data-menu-panel="get-involved" hidden>
    <div class="container">
      <ul class="site-nav__submenu-list">
        {getInvolvedLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
      </ul>
    </div>
  </div>

  <div class="site-nav__mobile-panel" id="mobile-nav-panel" data-mobile-nav-panel hidden>
    <div class="site-nav__mobile-content">
      <nav aria-label="Mobile main navigation">
        <ul class="site-nav__mobile-list">
          <li><a href="/">Home</a></li>
          <li>
            <details class="site-nav__mobile-accordion">
              <summary>About</summary>
              <ul>
                {aboutLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
              </ul>
            </details>
          </li>
          <li>
            <details class="site-nav__mobile-accordion">
              <summary>Get Involved</summary>
              <ul>
                {getInvolvedLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
              </ul>
            </details>
          </li>
          <li><a href="/on-the-ground">On The Ground</a></li>
        </ul>
      </nav>

      <div class="site-nav__mobile-actions">
        <a href="/donate" class="button button--yellow">Donate</a>
        <ExternalLink
          href="https://www.facebook.com"
          class="facebook-link"
          aria-label="Visit Nature Coast Indivisible on Facebook"
        >
          <img src="/images/facebook.svg" alt="" aria-hidden="true" />
        </ExternalLink>
      </div>
    </div>
  </div>
</header>

<script>
  const toggles = Array.from(document.querySelectorAll("[data-menu-toggle]"));
  const panels = Array.from(document.querySelectorAll("[data-menu-panel]"));

  const closeAllMenus = () => {
    toggles.forEach((toggle) => {
      toggle.setAttribute("aria-expanded", "false");
      toggle.classList.remove("is-open");
    });
    panels.forEach((panel) => {
      panel.setAttribute("hidden", "");
    });
  };

  toggles.forEach((toggle) => {
    toggle.addEventListener("click", () => {
      const menuName = toggle.getAttribute("data-menu-toggle");
      const panel = document.querySelector(`[data-menu-panel="${menuName}"]`);
      const isOpen = toggle.getAttribute("aria-expanded") === "true";

      closeAllMenus();
      if (!isOpen && panel) {
        toggle.setAttribute("aria-expanded", "true");
        toggle.classList.add("is-open");
        panel.removeAttribute("hidden");
      }
    });
  });

  document.addEventListener("click", (event) => {
    if (!(event.target instanceof Element)) return;
    if (event.target.closest(".site-nav")) return;
    closeAllMenus();
  });

  const mobileToggle = document.querySelector("[data-mobile-menu-toggle]");
  const mobilePanel = document.querySelector("[data-mobile-nav-panel]");
  const mobileLinks = Array.from(document.querySelectorAll(".site-nav__mobile-list a"));
  const mobileAccordions = Array.from(document.querySelectorAll(".site-nav__mobile-accordion"));

  const closeMobileMenu = () => {
    if (!mobileToggle || !mobilePanel) return;
    mobileToggle.setAttribute("aria-expanded", "false");
    mobileToggle.classList.remove("is-open");
    mobilePanel.setAttribute("hidden", "");
    document.body.classList.remove("mobile-menu-open");
    mobileAccordions.forEach((accordion) => accordion.removeAttribute("open"));
  };

  mobileToggle?.addEventListener("click", () => {
    if (!mobilePanel) return;
    const isOpen = mobileToggle.getAttribute("aria-expanded") === "true";
    mobileToggle.setAttribute("aria-expanded", isOpen ? "false" : "true");
    mobileToggle.classList.toggle("is-open", !isOpen);
    mobilePanel.toggleAttribute("hidden", isOpen);
    document.body.classList.toggle("mobile-menu-open", !isOpen);
  });

  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      closeMobileMenu();
    });
  });

  window.addEventListener("resize", () => {
    if (window.innerWidth > 900) closeMobileMenu();
  });
</script>
