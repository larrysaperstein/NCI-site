---
import { CALENDAR_CONFIG } from "../config/calendar";

interface Props {
  class?: string;
  /** When true, show every upcoming event instead of the homepage limit */
  showAll?: boolean;
  maxEvents?: number;
  headingTag?: "h2" | "h3";
}

const {
  class: className,
  showAll = false,
  maxEvents,
  headingTag = "h3",
} = Astro.props;

const resolvedMaxEvents = showAll ? undefined : (maxEvents ?? CALENDAR_CONFIG.maxEventsHome);
---

<div
  class:list={["home-events-grid", className]}
  data-events-grid
  data-max-events={resolvedMaxEvents}
  data-heading-tag={headingTag}
  aria-live="polite"
></div>

<script>
  import { initCalendarGrids } from "../scripts/calendar";

  initCalendarGrids();
</script>
