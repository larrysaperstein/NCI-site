---
import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";
import { withBase } from "../utils/path";
import "../styles/global.css";

interface Props {
  title?: string;
}

const SITE_NAME = "Nature Coast Indivisible";
const { title = SITE_NAME } = Astro.props;
const documentTitle = title === SITE_NAME ? SITE_NAME : `${title} - ${SITE_NAME}`;

const homeAboutBackground = withBase("/images/trees-bg.webp");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href={withBase("/images/logo-fallback.svg")} type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&display=swap"
      rel="stylesheet"
    />
    <title>{documentTitle}</title>
    <script is:inline>
      (function () {
        var hash = window.location.hash;
        if (!hash || !/invite_token|confirmation_token|recovery_token|email_change_token/.test(hash)) {
          return;
        }

        var path = window.location.pathname.replace(/\/$/, "");
        if (path !== "/cms" && path !== "/cms.html") {
          window.location.replace("/cms" + hash);
        }
      })();
    </script>
    <style is:global set:html={`
      .home-about::before {
        background-color: #fffbef;
        background-image: url("${homeAboutBackground}");
        background-blend-mode: multiply;
      }

      .home-section--events::before {
        background-image: url("${withBase("/images/bluetexture.webp")}");
      }
    `}></style>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
