---
import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";
import { withBase } from "../utils/path";
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Nature Coast Indivisible" } = Astro.props;

const homeAboutBackground = withBase("/images/trees-bg.webp");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <style is:global set:html={`
      .home-about::before {
        background-color: #fffbef;
        background-image: url("${homeAboutBackground}");
        background-blend-mode: multiply;
      }

      .home-section--events::before {
        background-image: url("${withBase("/images/bluetexture.webp")}");
      }
    `}></style>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
