---
import { getCollection, render } from "astro:content";
import ResourcesSection from "../components/ResourcesSection.astro";
import MainLayout from "../layouts/MainLayout.astro";

const resourceEntries = await getCollection("resourcesTabs");
const resources = await Promise.all(
  resourceEntries.map(async (entry) => {
    const { Content } = await render(entry);
    return {
      slug: entry.slug,
      ...entry.data,
      Content
    };
  })
);

resources.sort((a, b) => a.order - b.order);
---

<MainLayout title="Resources">
  <ResourcesSection resources={resources} />
</MainLayout>
