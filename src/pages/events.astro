---
import EventsGrid from "../components/EventsGrid.astro";
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Events">
  <section class="upcoming events-page">
    <div class="container">
      <h1>Events</h1>
      <p class="events-page__subtitle">Upcoming community gatherings, trainings, and organizing opportunities.</p>

      <EventsGrid class="events-page__grid" headingTag="h2" showAll />
    </div>
  </section>
</MainLayout>
