---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";

const leaders = (await getCollection("leadership")).sort((a, b) => a.data.order - b.data.order);
---

<MainLayout title="Leadership">
  <section class="upcoming leadership-page">
    <div class="container">
      <h1>Leadership</h1>
      <p class="leadership-page__subtitle">
        Have a question? Email us at <a href="mailto:naturecoastindivisible@gmail.com" class="leadership-page__email-link">naturecoastindivisible@gmail.com</a> and a member of our leadership will get back to you!
      </p>

      {
        leaders.length > 0 ? (
          <div class="leadership__cards">
            {
              leaders.map((leader) => (
                <article class="leadership-card">
                  <div class="leadership-card__content">
                    <h2 class="leadership-card__name">{leader.data.name}</h2>
                    <p class="leadership-card__role">{leader.data.role}</p>
                  </div>
                </article>
              ))
            }
          </div>
        ) : (
          <p class="leadership-page__empty">Leadership profiles will appear here once they are added in the CMS.</p>
        )
      }
    </div>
  </section>
</MainLayout>
