---
import { getCollection, getEntry, render } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";
import { getActionItemPublicSlug, type ActionCollection } from "../../utils/actionItems";
import { withBase } from "../../utils/path";

export async function getStaticPaths() {
  const immediateEntries = await getCollection("immediateAction");
  const ongoingEntries = await getCollection("ongoingAction");

  return [
    ...immediateEntries.map((entry) => ({
      params: { slug: getActionItemPublicSlug(entry.slug, "immediateAction") },
      props: { collection: "immediateAction" as ActionCollection, fileSlug: entry.slug }
    })),
    ...ongoingEntries.map((entry) => ({
      params: { slug: getActionItemPublicSlug(entry.slug, "ongoingAction") },
      props: { collection: "ongoingAction" as ActionCollection, fileSlug: entry.slug }
    }))
  ];
}

const { slug } = Astro.params;
const { collection, fileSlug } = Astro.props;

if (!slug) throw new Error("Missing action item slug");

const entry = await getEntry(collection, fileSlug);
if (!entry) {
  throw new Error(`Action item not found for slug: ${slug}`);
}

const { Content } = await render(entry);
---

<MainLayout title={entry.data.headline}>
  <section class="upcoming ground-post action-post">
    <div class="container">
      <a href={withBase("/action-items")} class="ground-post__back-link">
        <img src={withBase("/images/arrow-left.svg")} alt="" aria-hidden="true" />
        Back To All Action Items
      </a>

      <article class="ground-post__article">
        <header class="ground-post__header">
          {"priority" in entry.data && entry.data.priority === "high" && <p class="action-post__badge">Top Priority</p>}
          <h1>{entry.data.headline}</h1>
          <img src={withBase(entry.data.avatarImage || "/images/logo-fallback.svg")} alt={entry.data.avatarAlt || entry.data.headline} loading="lazy" />
          {entry.data.subheading && <p class="ground-post__subheading">{entry.data.subheading}</p>}
        </header>
        <div class="ground-post__content">
          <Content />
        </div>
      </article>
    </div>
  </section>
</MainLayout>
