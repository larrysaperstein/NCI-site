---
import MainLayout from "../layouts/MainLayout.astro";
import { getCollection, render } from "astro:content";
import { getActionItemPublicSlug } from "../utils/actionItems";
import { withBase } from "../utils/path";

const actionItemsCards = await Promise.all(
  (await getCollection("immediateAction")).map(async (entry) => {
    const { Content } = await render(entry);
    return {
      ...entry.data,
      slug: getActionItemPublicSlug(entry.slug, "immediateAction"),
      Content
    };
  })
);

const inTheMeantimeCards = await Promise.all(
  (await getCollection("ongoingAction")).map(async (entry) => {
    const { Content } = await render(entry);
    return {
      ...entry.data,
      slug: getActionItemPublicSlug(entry.slug, "ongoingAction"),
      Content
    };
  })
);

const sortByOrder = (a: { order: number }, b: { order: number }) => a.order - b.order;
actionItemsCards.sort(sortByOrder);
inTheMeantimeCards.sort(sortByOrder);
---

<MainLayout title="Take Action">
  <section class="upcoming upcoming--actions">
    <div class="container">
      <h1>Action Items</h1>

      <div class="upcoming__content ground__content upcoming--actions__content">
        <aside class="upcoming__tabs" aria-label="Upcoming sections">
          <button
            type="button"
            class="upcoming__tab upcoming__tab--active"
            data-upcoming-tab="action-items"
            aria-selected="true"
          >
            Immediate Action
          </button>
          <button type="button" class="upcoming__tab" data-upcoming-tab="in-the-meantime" aria-selected="false">
            Ongoing Action
          </button>
        </aside>

        <div class="ground__panels upcoming__panels">
          <div class="upcoming__panel ground__panel is-active" data-upcoming-panel="action-items">
            <div class="ground__cards">
              {
                actionItemsCards.map((card) => (
                  <a
                    href={withBase(`/action-items/${card.slug}/`)}
                    class={`ground-card action-card${card.priority === "high" ? " action-card--priority" : ""}`}
                    aria-label={`Read ${card.headline}`}
                  >
                    {card.priority === "high" && <span class="action-card__badge">Top Priority</span>}
                    <img
                      class="ground-card__image"
                      src={withBase(card.avatarImage || "/images/logo-fallback.svg")}
                      alt={card.avatarAlt || card.headline}
                      loading="lazy"
                    />
                    <div class="ground-card__content">
                      <h2>{card.headline}</h2>
                      {card.subheading && <p class="ground-card__subheading">{card.subheading}</p>}
                      <p class="action-card__cta">View Action Details</p>
                    </div>
                  </a>
                ))
              }
            </div>
          </div>

          <div class="upcoming__panel ground__panel" data-upcoming-panel="in-the-meantime" hidden>
            <div class="ground__cards">
              {
                inTheMeantimeCards.map((card) => (
                  <a
                    href={withBase(`/action-items/${card.slug}/`)}
                    class="ground-card action-card"
                    aria-label={`Read ${card.headline}`}
                  >
                    <img
                      class="ground-card__image"
                      src={withBase(card.avatarImage || "/images/logo-fallback.svg")}
                      alt={card.avatarAlt || card.headline}
                      loading="lazy"
                    />
                    <div class="ground-card__content">
                      <h2>{card.headline}</h2>
                      {card.subheading && <p class="ground-card__subheading">{card.subheading}</p>}
                      <p class="action-card__cta">View Action Details</p>
                    </div>
                  </a>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<script>
  const tabs = Array.from(document.querySelectorAll("[data-upcoming-tab]"));
  const panels = Array.from(document.querySelectorAll("[data-upcoming-panel]"));

  const showPanel = (tabName) => {
    tabs.forEach((tab) => {
      const isActive = tab.getAttribute("data-upcoming-tab") === tabName;
      tab.classList.toggle("upcoming__tab--active", isActive);
      tab.setAttribute("aria-selected", isActive ? "true" : "false");
    });

    panels.forEach((panel) => {
      const isActive = panel.getAttribute("data-upcoming-panel") === tabName;
      if (isActive) {
        panel.removeAttribute("hidden");
        panel.classList.remove("is-fading");
        requestAnimationFrame(() => panel.classList.add("is-fading"));
      } else {
        panel.setAttribute("hidden", "");
        panel.classList.remove("is-fading");
      }
    });
  };

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const tabName = tab.getAttribute("data-upcoming-tab");
      if (!tabName) return;
      showPanel(tabName);
    });
  });
</script>
